# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
# Signs the Flask session cookie every organizer request authenticates with. REQUIRED: the app
# refuses to boot without it (unless ALLOW_INSECURE_LOCAL_DEV is set, which signs with a random
# per-process key instead). There is deliberately NO default - a fallback secret committed to a
# repository is a published key, and anyone holding it can forge a session for any organizer and read
# and write their markets, vendors and applications with no password and no login.
# Generate one with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
SECRET_KEY=

# Local-development escape hatch (default OFF). The app REFUSES TO BOOT without all four of
# SECRET_KEY, RECAPTCHA_SECRET_KEY, CORS_ALLOWED_ORIGINS and RESEND_API_KEY. Set this to `true` on a
# development machine to boot without them anyway; everything it turns off is named in the log.
# NEVER set it on a deployed environment - it is the one thing standing between a forgotten variable
# and an open mail relay. Deliberately not keyed on FLASK_ENV: that defaults to `development` in the
# Dockerfile, so a check gated on it would exempt exactly the deployments that need it. The same four
# are listed under "Required Production Environment" in docs/RELEASING.md.
ALLOW_INSECURE_LOCAL_DEV=

# The browser origins allowed to make credentialed requests to this API, comma-separated, each
# written exactly as a browser sends it: scheme://host[:port], no trailing slash, no path. The
# organizer's session cookie is SameSite=None, so the browser attaches it to cross-site requests -
# which makes this list the only thing standing between the organizer API and any website an
# organizer happens to visit. REQUIRED (the app refuses to boot without it, unless
# ALLOW_INSECURE_LOCAL_DEV is set, which allows loopback origins on any port instead). There is no
# default and `*` is refused: a credentialed wildcard is not a permissive policy, it is no policy.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Session Configuration
# 'filesystem' (the default) keeps sessions on disk. A serverless deployment has no disk that
# outlives a request and MUST set 'null', which keeps the session in the signed cookie only.
SESSION_TYPE=filesystem

# MongoDB Configuration
# Option 1: MongoDB Atlas connection string (recommended for Vercel)
# When using MongoDB Atlas provisioned from Vercel Marketplace, MONGODB_URI is automatically set
# For manual setup, get your connection string from MongoDB Atlas dashboard
# Format: mongodb+srv://username:password@cluster.mongodb.net/conventioner?retryWrites=true&w=majority
MONGODB_URI=

# Option 2: Traditional MongoDB connection (for local development)
# Only used if MONGODB_URI is not set
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=admin
MONGODB_PASSWORD=secret
MONGODB_DB=conventioner
MONGODB_AUTH_DB=admin

# Email Service (Resend)
# Get your API key from https://resend.com/api-keys
# REQUIRED: it delivers the email-verification link, the password-reset link, and the OTP login code
# - every route by which an organizer account is reached. With no key, registration rolls the account
# back and answers 500, an unverified organizer can never log in, and reset and OTP answer 500 too:
# not a degraded deployment, one that cannot onboard anybody. The app refuses to boot without it,
# unless ALLOW_INSECURE_LOCAL_DEV is set.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=onboarding@resend.dev
FRONTEND_URL=http://localhost:5173

# CAPTCHA Service (Google reCAPTCHA v3)
# Get your keys from https://www.google.com/recaptcha/admin
# REQUIRED: the public organizer signup endpoint is gated on it, and with no secret there is nothing
# to verify a token against, so the gate would pass every caller. The app refuses to boot without it
# - rather than serve that endpoint open - unless ALLOW_INSECURE_LOCAL_DEV is set.
RECAPTCHA_SECRET_KEY=6Lcxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Test-only CAPTCHA bypass (default OFF). Set to `true` or `1` to skip reCAPTCHA
# verification for local development or E2E testing. Honored ONLY when
# ALLOW_INSECURE_LOCAL_DEV is also set, so it cannot be a live bypass on a deployment
# that merely forgot to unset it.
DISABLE_CAPTCHA=

# Test-only email bypass (default OFF). Set to `true` or `1` to skip sending
# verification, password reset, and OTP emails via Resend (they are treated as
# sent successfully) for local development or E2E testing. Honored ONLY when
# ALLOW_INSECURE_LOCAL_DEV is also set, so a deployment that inherited it from a
# copied env file cannot silently swallow every verification and reset link it owes.
DISABLE_EMAIL=

# Figma MCP (local development tooling)
# Get your personal access token from Figma → Settings → Personal access tokens
FIGMA_API_KEY=
