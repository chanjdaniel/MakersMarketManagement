# This file is the LOCAL DEVELOPMENT template, and it is meant to boot as it stands: copy it to
# `.env` and the back end starts, with no accounts to sign up for and no keys to go and fetch. What
# makes that safe is the escape hatch below - it is opt-in, it is loud, and nothing a deployment
# inherits from this repository sets it. See docs/RELEASING.md for what a deployment must set.

# Flask Configuration
# FLASK_APP only. FLASK_ENV is gone from this repository entirely - nothing reads it, and the two
# checks that used to are the two vulnerabilities the boot check closes: our own image exported
# `development`, so a control keyed on it read `development` on every deployment too. A variable
# nobody sets is a variable nobody can key on.
FLASK_APP=app.py

# Local-development escape hatch (default OFF; ON in this template, which is a local-development
# one). The app REFUSES TO BOOT without all six of SECRET_KEY, RECAPTCHA_SECRET_KEY,
# CORS_ALLOWED_ORIGINS, RESEND_API_KEY, SESSION_TYPE and TRUSTED_PROXY_HOPS. Set to `true` on a
# development machine to boot without them anyway; everything it turns off is named in the log.
# NEVER set it on a deployed environment - it is the one thing standing between a forgotten variable
# and an open mail relay. It is one variable, it means one thing, and it is opt-in: a check keyed on
# anything whose default is the insecure value (as the old FLASK_ENV gate was) exempts exactly the
# deployments that need it. The same six are listed under "Required Production Environment" in
# docs/RELEASING.md.
ALLOW_INSECURE_LOCAL_DEV=true

# Signs the Flask session cookie every organizer request authenticates with. REQUIRED: the app
# refuses to boot without it (unless ALLOW_INSECURE_LOCAL_DEV is set, as it is above, which signs
# with a random per-process key instead - so a restart logs you out, and nothing else changes).
# There is deliberately NO default: a fallback secret committed to a repository is a published key,
# and anyone holding it can forge a session for any organizer and read and write their markets,
# vendors and applications with no password and no login. For the same reason, every value this
# repository has ever printed as a signing key is REFUSED by name - do not paste one back in here.
# Generate one with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
SECRET_KEY=

# The browser origins allowed to make credentialed requests to this API, comma-separated, each
# written exactly as a browser sends it: scheme://host[:port], no trailing slash, no path. The
# organizer's session cookie is SameSite=None, so the browser attaches it to cross-site requests -
# which makes this list the only thing standing between the organizer API and any website an
# organizer happens to visit. REQUIRED (the app refuses to boot without it, unless
# ALLOW_INSECURE_LOCAL_DEV is set, which allows loopback origins on any port instead). There is no
# default and `*` is refused: a credentialed wildcard is not a permissive policy, it is no policy.
# Left BLANK here so the hatch's loopback pattern is what applies: a value here would override it, and
# pinning port 5173 refuses the browser the moment Vite lands on 5174 (routine - 5173 already in use)
# or the app is opened at 127.0.0.1 instead of localhost.
CORS_ALLOWED_ORIGINS=

# How many proxies of this deployment's own a request passes through before it reaches Flask: a
# reverse proxy, a load balancer, or a serverless ingress each count as one. REQUIRED (the app
# refuses to boot without it, unless ALLOW_INSECURE_LOCAL_DEV is set, which trusts none). Stated
# rather than left to the hatch here, because 0 is the truth on a laptop: nothing sits in front of
# Flask, so the peer address IS the caller's. Unset is not zero, it is unknown, and behind a proxy an
# unknown value makes the ingress's address the one this app takes for every caller's - which is the
# address organizer signup reports to reCAPTCHA, and reCAPTCHA v3 scores on it. Vercel is 1.
TRUSTED_PROXY_HOPS=0

# Session Configuration
# Where the organizer's session is kept. REQUIRED (the app refuses to boot without it, unless
# ALLOW_INSECURE_LOCAL_DEV is set, which keeps sessions on disk). There is deliberately NO default,
# because neither value is right for both hosts: 'filesystem' keeps sessions on local disk, which is
# what a container or a VM has, while a serverless deployment (Vercel) has no disk that outlives a
# request and MUST set 'null', which keeps the session in the signed cookie only. This used to be
# derived from FLASK_ENV, which our own image pinned to `development`, so the derivation handed
# 'filesystem' to exactly the deployments with no filesystem.
SESSION_TYPE=filesystem

# MongoDB Configuration
# Option 1: MongoDB Atlas connection string (recommended for Vercel)
# When using MongoDB Atlas provisioned from Vercel Marketplace, MONGODB_URI is automatically set
# For manual setup, get your connection string from MongoDB Atlas dashboard
# Format: mongodb+srv://username:password@cluster.mongodb.net/conventioner?retryWrites=true&w=majority
MONGODB_URI=

# Option 2: Traditional MongoDB connection (for local development)
# Only used if MONGODB_URI is not set
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=admin
MONGODB_PASSWORD=secret
MONGODB_DB=conventioner
MONGODB_AUTH_DB=admin

# Email Service (Resend)
# Get your API key from https://resend.com/api-keys
# REQUIRED: it delivers the email-verification link, the password-reset link, and the OTP login code
# - every route by which an organizer account is reached. With no key, registration rolls the account
# back and answers 500, an unverified organizer can never log in, and reset and OTP answer 500 too:
# not a degraded deployment, one that cannot onboard anybody. The app refuses to boot without it,
# unless ALLOW_INSECURE_LOCAL_DEV is set. Left BLANK here, with DISABLE_EMAIL below: a placeholder
# would be truthy, and a truthy placeholder is worse than a blank - the app would take it for a
# configured key and try to send real mail with it. The placeholders this repo has published (such
# as `re_xxxxx`) are refused by name at boot, so pasting one in is not a way past the check either.
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev
FRONTEND_URL=http://localhost:5173

# Test-only email bypass (default OFF; ON in this template). Set to `true` or `1` to skip sending
# verification, password reset, and OTP emails via Resend (they are treated as sent successfully)
# for local development or E2E testing. Honored ONLY when ALLOW_INSECURE_LOCAL_DEV is also set, so a
# deployment that inherited it from a copied env file cannot silently swallow every verification and
# reset link it owes.
DISABLE_EMAIL=true

# CAPTCHA Service (Google reCAPTCHA v3)
# Get your keys from https://www.google.com/recaptcha/admin
# REQUIRED: the public organizer signup endpoint is gated on it, and with no secret there is nothing
# to verify a token against, so the gate would pass every caller. The app refuses to boot without it
# - rather than serve that endpoint open - unless ALLOW_INSECURE_LOCAL_DEV is set. Left BLANK here,
# with DISABLE_CAPTCHA below: a placeholder is truthy, so the app would take it for a real secret and
# verify every signup token against a key Google has never heard of - which fails every local signup
# with nothing to point at. The placeholders this repo has published (such as `6Lcxxxxx`) are
# refused by name at boot, so pasting one in is not a way past the check either.
RECAPTCHA_SECRET_KEY=

# Test-only CAPTCHA bypass (default OFF; ON in this template). Set to `true` or `1` to skip reCAPTCHA
# verification for local development or E2E testing. Honored ONLY when ALLOW_INSECURE_LOCAL_DEV is
# also set, so it cannot be a live bypass on a deployment that merely forgot to unset it.
DISABLE_CAPTCHA=true

# Figma MCP (local development tooling)
# Get your personal access token from Figma → Settings → Personal access tokens
FIGMA_API_KEY=
