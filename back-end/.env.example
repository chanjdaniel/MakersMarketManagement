# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
# Signs the Flask session cookie and the application-scoped tokens the public applicant endpoints
# authenticate with. REQUIRED: the app refuses to boot without it (unless ALLOW_INSECURE_LOCAL_DEV is
# set, which signs with a random per-process key instead). There is deliberately NO default - a
# fallback secret committed to a repository is a published key, and anyone holding it can mint an
# applicant token for any application and walk past the one-time code, the captcha, and every rate
# limit. Generate one with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
SECRET_KEY=
USE_HTTPS=true

# Local-development escape hatch (default OFF). The app REFUSES TO BOOT without
# RECAPTCHA_SECRET_KEY and TRUSTED_PROXY_HOPS, because the public applicant endpoints lose both of
# their defenses silently when those are unset. Set this to `true` on a development machine to boot
# without them anyway; every defense it turns off is named in the log. NEVER set it on a deployed
# environment - it is the one thing standing between a forgotten variable and an open mail relay.
# Deliberately not keyed on FLASK_ENV: that defaults to `development` in the Dockerfile, so a check
# gated on it would exempt exactly the deployments that need it.
ALLOW_INSECURE_LOCAL_DEV=

# How many proxies of your own a request passes through before it reaches Flask: a reverse proxy,
# a load balancer, or a serverless ingress each count as one. The public applicant endpoints key
# their rate limits on the caller's address, and only the trusted hops' X-Forwarded-For entries may
# be believed - a client-supplied one is a limit an attacker resets per request, and no hops at all
# behind a proxy is one shared budget that locks out every real applicant. REQUIRED (the app refuses
# to boot without it, unless ALLOW_INSECURE_LOCAL_DEV is set); 0 means Flask is exposed directly.
TRUSTED_PROXY_HOPS=0

# Session Configuration
# For Vercel serverless: use 'null' (stores sessions in cookies only)
# For local development: use 'filesystem' (default)
SESSION_TYPE=filesystem

# MongoDB Configuration
# Option 1: MongoDB Atlas connection string (recommended for Vercel)
# When using MongoDB Atlas provisioned from Vercel Marketplace, MONGODB_URI is automatically set
# For manual setup, get your connection string from MongoDB Atlas dashboard
# Format: mongodb+srv://username:password@cluster.mongodb.net/conventioner?retryWrites=true&w=majority
MONGODB_URI=

# Option 2: Traditional MongoDB connection (for local development)
# Only used if MONGODB_URI is not set
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=admin
MONGODB_PASSWORD=secret
MONGODB_DB=conventioner
MONGODB_AUTH_DB=admin

# Email Service (Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=onboarding@resend.dev
FRONTEND_URL=http://localhost:5173

# CAPTCHA Service (Google reCAPTCHA v3)
# Get your keys from https://www.google.com/recaptcha/admin
# REQUIRED: the public applicant and signup endpoints are gated on it, and with no secret there is
# nothing to verify a token against, so the gate would pass every caller. The app refuses to boot
# without it - rather than serve those endpoints open - unless ALLOW_INSECURE_LOCAL_DEV is set.
RECAPTCHA_SECRET_KEY=6Lcxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Test-only CAPTCHA bypass (default OFF). Set to `true` or `1` to skip reCAPTCHA
# verification for local development or E2E testing. Honored ONLY when
# ALLOW_INSECURE_LOCAL_DEV is also set, so it cannot be a live bypass on a deployment
# that merely forgot to unset it.
DISABLE_CAPTCHA=

# Test-only email bypass (default OFF). Set to `true` or `1` to skip sending
# verification, password reset, and OTP emails via Resend (they are treated as
# sent successfully) for local development or E2E testing. Honored ONLY when
# ALLOW_INSECURE_LOCAL_DEV is also set, so a deployment that inherited it from a
# copied env file cannot silently swallow the applicant's login code.
DISABLE_EMAIL=

# Figma MCP (local development tooling)
# Get your personal access token from Figma → Settings → Personal access tokens
FIGMA_API_KEY=
