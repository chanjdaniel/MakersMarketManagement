# Docker Compose Environment Variables
# These variables are used by docker-compose.yml
# Copy this file to .env and fill in your actual values

# Email Service (Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend URL for email links
FRONTEND_URL=http://localhost:5173

# Email sender address (must be verified in Resend)
FROM_EMAIL=onboarding@resend.dev

# CAPTCHA Service (Google reCAPTCHA v3)
# Get your keys from https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=6Lcxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RECAPTCHA_SITE_KEY=6Lcxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Test-only CAPTCHA bypass (default OFF). Set to `true` or `1` to skip reCAPTCHA
# verification, e.g. for local E2E testing. Honored only by a back end that has also
# been told it is a local development one (ALLOW_INSECURE_LOCAL_DEV, which
# docker-compose.yml sets), so it cannot be a live bypass on a deployment.
DISABLE_CAPTCHA=

# Test-only email bypass (default OFF). Set to `true` or `1` to skip sending
# verification, password reset, and OTP emails via Resend (they are treated as
# sent successfully), e.g. for local E2E testing. Honored only by a back end that
# has also been told it is a local development one (ALLOW_INSECURE_LOCAL_DEV).
DISABLE_EMAIL=

# Vision AI (Optional — for AI-powered floorplan auto-detection)
# Get your Gemini API key from https://aistudio.google.com/apikey
# Get your OpenAI API key from https://platform.openai.com/api-keys
GEMINI_API_KEY=
OPENAI_API_KEY=
