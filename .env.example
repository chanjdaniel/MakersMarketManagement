# Docker Compose Environment Variables
# These variables are used by docker-compose.yml
# Copy this file to .env: the stack comes up as it stands, with no accounts to sign up for and no
# keys to go and fetch. What makes that safe is that docker-compose.yml sets ALLOW_INSECURE_LOCAL_DEV
# - it is opt-in, it is loud, and nothing a deployment inherits from this repository sets it.
# See docs/RELEASING.md for what a deployment must set.
#
# Every secret below is left BLANK on purpose, and the bypasses beside them are on. A placeholder
# would be worse than a blank: the boot check asks whether a secret is configured, a placeholder is
# truthy, and so the app would take `re_xxxxx` for a key and try to send real mail with it. Values
# this repository has published are refused by name for that reason (back-end/utils/configured_secret.py),
# so pasting one back in is not the way past a boot refusal either.

# Email Service (Resend)
# Get your API key from https://resend.com/api-keys
# REQUIRED on a deployment: it delivers the email-verification link, the password-reset link, and the
# OTP login code, so with no key no organizer can get an account at all. The back end refuses to boot
# without it. Blank here: the escape hatch above covers it, and DISABLE_EMAIL below skips the send
# entirely for local runs.
RESEND_API_KEY=

# Frontend URL for email links. It has no say in CORS - see CORS_ALLOWED_ORIGINS below.
FRONTEND_URL=http://localhost:5173

# The browser origins allowed to make credentialed requests to the back end, comma-separated, each
# written as a browser sends it (scheme://host[:port], no trailing slash). REQUIRED on a deployment:
# the session cookie is SameSite=None, so with no list every website an organizer visits could read
# and write the organizer API as them. `*` is refused. Blank here: docker-compose.yml sets
# ALLOW_INSECURE_LOCAL_DEV, which allows loopback origins on any port, so the dev server's port can
# move (as it does per worktree) without this having to be kept in step.
CORS_ALLOWED_ORIGINS=

# Email sender address (must be verified in Resend)
FROM_EMAIL=onboarding@resend.dev

# CAPTCHA Service (Google reCAPTCHA v3)
# Get your keys from https://www.google.com/recaptcha/admin
# RECAPTCHA_SECRET_KEY is REQUIRED on a deployment: the public organizer signup endpoint is gated on
# it, and with no secret there is nothing to verify a token against. Both are blank here, and both
# have to be: a placeholder secret verifies every signup against a key Google never issued, and a
# placeholder site key makes the browser load a reCAPTCHA widget for a key that does not exist. With
# the site key empty, the front end sends a placeholder token and the back end applies DISABLE_CAPTCHA.
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=

# Test-only CAPTCHA bypass (default OFF; ON in this template). Set to `true` or `1` to skip reCAPTCHA
# verification, e.g. for local E2E testing. Honored only by a back end that has also been told it is
# a local development one (ALLOW_INSECURE_LOCAL_DEV, which docker-compose.yml sets), so it cannot be
# a live bypass on a deployment.
DISABLE_CAPTCHA=true

# Test-only email bypass (default OFF; ON in this template). Set to `true` or `1` to skip sending
# verification, password reset, and OTP emails via Resend (they are treated as sent successfully),
# e.g. for local E2E testing. Honored only by a back end that has also been told it is a local
# development one (ALLOW_INSECURE_LOCAL_DEV).
DISABLE_EMAIL=true

# Vision AI (Optional - for AI-powered floorplan auto-detection)
# Get your Gemini API key from https://aistudio.google.com/apikey
# Get your OpenAI API key from https://platform.openai.com/api-keys
GEMINI_API_KEY=
OPENAI_API_KEY=
