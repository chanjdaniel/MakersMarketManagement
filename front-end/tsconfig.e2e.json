{
  "extends": "@tsconfig/node22/tsconfig.json",
  "include": ["e2e/**/*.ts"],
  "compilerOptions": {
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.e2e.tsbuildinfo",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["es2024", "ESNext.Array", "ESNext.Collection", "ESNext.Iterator", "dom"],
    "types": ["node"]
  }
}
