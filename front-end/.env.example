# API Configuration
VITE_FLASK_HOST=/api
VITE_BACKEND_URL=https://localhost:5000

# CAPTCHA Service (Google reCAPTCHA v3)
# Get your site key from https://www.google.com/recaptcha/admin
# Leave empty in test/dev builds: executeRecaptcha() returns a placeholder token
# so the flow still reaches the backend, which applies its own DISABLE_CAPTCHA bypass.
VITE_RECAPTCHA_SITE_KEY=6Lcxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
