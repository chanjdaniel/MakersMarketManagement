# API Configuration
VITE_FLASK_HOST=/api
VITE_BACKEND_URL=https://localhost:5000

# CAPTCHA Service (Google reCAPTCHA v3)
# Get your site key from https://www.google.com/recaptcha/admin.
# It must be the site key of the same reCAPTCHA property as the back end's RECAPTCHA_SECRET_KEY:
# the two are a pair, and a front end holding neither, or one from a different property, ships a
# product nobody can sign up for.
# Blank in test/dev builds, and blank is what this template ships: executeRecaptcha() returns a
# placeholder token when it is empty, so the flow still reaches the backend, which applies its own
# DISABLE_CAPTCHA bypass. A placeholder here would not be empty - the browser would load a reCAPTCHA
# widget for a key that does not exist, and local signup would fail with nothing to point at.
VITE_RECAPTCHA_SITE_KEY=

# The one thing that lets `npm run build` produce a bundle with no site key above. It is opt-in and
# it is only true here, in the local-development template - a deployed build must set a real site
# key, and `vite build` refuses without one, because the bundle would otherwise send a placeholder
# token that the back end verifies against Google and Google rejects: a 400 per signup, naming none
# of it. See front-end/vite.config.ts, and ALLOW_INSECURE_LOCAL_DEV in back-end/.env.example.
VITE_ALLOW_INSECURE_LOCAL_DEV=true
